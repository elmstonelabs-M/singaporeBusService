APP_ENV=development
APP_NAME=Singapore Bus Arrival API
APP_VERSION=0.1.0
DEBUG=true
APP_TIMEZONE=Asia/Singapore

DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/bus_app
REDIS_URL=redis://localhost:6379/0

LTA_ACCOUNT_KEY=replace_with_real_key
LTA_BASE_URL=https://datamall2.mytransport.sg/ltaodataservice
LTA_TIMEOUT_SECONDS=5
FEEDBACK_TO_EMAIL=elmstonelabs@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

DEFAULT_ARRIVAL_CACHE_TTL_SECONDS=20
DEFAULT_LAST_GOOD_CACHE_TTL_SECONDS=300
DEFAULT_NEARBY_CACHE_TTL_SECONDS=60
DEFAULT_SEARCH_CACHE_TTL_SECONDS=86400
DEFAULT_HOME_CACHE_TTL_SECONDS=15
FEEDBACK_DAILY_LIMIT_PER_CLIENT_ID=6
FEEDBACK_DAILY_LIMIT_PER_IP=18
DATASET_STORAGE_DIR=datasets

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
LOG_FILE_PATH=
