APP_ENV=production
APP_NAME=Singapore Bus Arrival API
APP_VERSION=0.1.0
DEBUG=false

DATABASE_URL=postgresql+asyncpg://bus_app:change_me@postgres:5432/bus_app
REDIS_URL=redis://:change_me@redis:6379/0

LTA_ACCOUNT_KEY=replace_with_real_key
LTA_BASE_URL=https://datamall2.mytransport.sg/ltaodataservice
LTA_TIMEOUT_SECONDS=5

DEFAULT_ARRIVAL_CACHE_TTL_SECONDS=20
DEFAULT_LAST_GOOD_CACHE_TTL_SECONDS=300
DEFAULT_NEARBY_CACHE_TTL_SECONDS=60
DEFAULT_SEARCH_CACHE_TTL_SECONDS=86400
DEFAULT_HOME_CACHE_TTL_SECONDS=15
DATASET_STORAGE_DIR=/app/datasets

CORS_ORIGINS=https://your-frontend-domain.example.com
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/logs/app.log

POSTGRES_DB=bus_app
POSTGRES_USER=bus_app
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
